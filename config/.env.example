# ============================================================
# KOSPI Analyzer 환경변수 템플릿 (SEC-5)
# ============================================================
# 사용법:
#   1) cp config/.env.example config/.env
#   2) 아래 값들을 실제 운영값으로 채워 넣는다.
#   3) config/.env는 .gitignore에 의해 절대 커밋되지 않는다.
#
# 보안 주의:
#   - 본 파일은 형식 가이드일 뿐, 실제 자격증명을 담지 말 것.
#   - 키가 노출되면 즉시 발급사에서 회전(rotate)하라.
#   - DART/KIS는 일일 호출 한도가 있으니 키 공유 금지.
#   - 실제 .env는 600 퍼미션 권장 (chmod 600 config/.env).
# ============================================================

# ---- KIS Open API (필수) -----------------------------------
# https://apiportal.koreainvestment.com 발급
KIS_APP_KEY=replace-me
KIS_APP_SECRET=replace-me
# 모의투자 계좌라면 8자리-2자리 형식 (옵션, 시세조회만 한다면 비워도 됨)
KIS_ACCOUNT_NO=
# 모의 투자(true) vs 실거래(false). 시세 분석 전용이면 true 권장.
KIS_IS_PAPER_TRADING=true
# 호스트 (모의: openapivts, 실거래: openapi)
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
# 초당 호출 한도 — 공식 한도 20, 안전 마진 25% 확보로 기본 15.
KIS_RATE_LIMIT_PER_SEC=15

# ---- DART Open API (필수) ----------------------------------
# https://opendart.fss.or.kr/ 발급
DART_API_KEY=replace-me

# ---- Telegram Bot (필수) -----------------------------------
# @BotFather에게 /newbot으로 생성한 토큰
TELEGRAM_BOT_TOKEN=replace-me
# 봇과 첫 대화 후 https://api.telegram.org/bot<TOKEN>/getUpdates로 확인
TELEGRAM_CHAT_ID=replace-me
# 에러 알림 별도 채널 (옵션, 미지정 시 TELEGRAM_CHAT_ID로 발송)
TELEGRAM_ERROR_CHAT_ID=
# 콤마 구분 화이트리스트 (옵션, 미지정 시 TELEGRAM_CHAT_ID 단일 허용)
TELEGRAM_ALLOWED_CHAT_IDS=

# ---- 운영 (옵션, 모두 기본값 있음) -------------------------
TIMEZONE=Asia/Seoul
DB_PATH=data/kospi_analyzer.db
LOG_LEVEL=INFO
